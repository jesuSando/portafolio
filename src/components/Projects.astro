---
import * as icon from "lucide-react";

const projects = [
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        details: "Descripción detallada del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        details: "Descripción detallada del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
];

const moreProjects = [
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        details: "Descripción detallada del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        details: "Descripción detallada del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        details: "Descripción detallada del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
];
---

<section
    id="projects"
    class="min-h-screen flex flex-col container mx-auto px-6 md:px-20 py-20 space-y-10"
>
    <h2 class="text-2xl md:text-5xl font-bold gradient-text-green py-3">
        Proyectos Destacados
    </h2>
    <p class="text-xl">
        Una selección de proyectos personales y profesionales donde aplico mis
        conocimientos en frontend y backend, resolviendo problemas reales.
    </p>
    <div class="flex w-full items-center justify-between gap-6">
        {
            projects.map((project) => {
                return (
                    <div
                        class="flex-1 rounded-2xl transition-all duration-300
                    bg-white/5 backdrop-blur-sm border border-white/10"
                    >
                        <div class="relative h-100 overflow-hidden group">
                            <div
                                class="absolute inset-0 z-10 pointer-events-none
                                bg-linear-to-t from-black/70 to-transparent
                                opacity-0 transition-opacity duration-300
                                group-hover:opacity-100 flex items-end p-4"
                            >
                                {project.details}
                            </div>

                            <img
                                src={project.image}
                                alt={project.title}
                                class="w-full h-full object-cover
                                transition-transform duration-300
                                group-hover:scale-110"
                            />
                        </div>
                        <div class="p-6 space-y-4">
                            <h3 class="text-xl md:text-2xl font-bold text-white">
                                {project.title}
                            </h3>
                            <p class="text-gray-300">{project.description}</p>
                            <div class="flex space-x-2">
                                {project.stack.map((tech) => (
                                    <span class="px-2 py-1 bg-white/10 rounded-lg text-sm text-gray-300">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                            <div class="flex space-x-4 mt-6">
                                <a
                                    href={project.repo}
                                    class="flex items-center justify-center gap-2 rounded-full bg-amber-900/20 border border-amber-800 text-amber-400 hover:bg-amber-900/40 hover:border-amber-600 px-6 py-3 font-semibold transition-all duration-300"
                                >
                                    <icon.Github className="h-5 w-5" />
                                    Código
                                </a>

                                <a
                                    href={project.demo}
                                    class="flex items-center justify-center gap-2 rounded-full bg-cyan-900/20 border border-cyan-800 text-cyan-400 hover:bg-cyan-900/40 hover:border-cyan-600 px-6 py-3 font-semibold transition-all duration-300"
                                >
                                    <icon.ExternalLink className="h-5 w-5" />
                                    Live Demo
                                </a>
                            </div>
                        </div>
                    </div>
                );
            })
        }
    </div>

    <h2 class="text-xl md:text-4xl font-bold text-white py-3">Más Proyectos</h2>

    <div class="flex w-full items-center justify-between gap-6">
        {
            moreProjects.map((project) => {
                return (
                    <div
                        class="flex-1 rounded-2xl transition-all duration-300
                    bg-white/5 backdrop-blur-sm border border-white/10"
                    >
                        <div class="relative h-100 overflow-hidden group">
                            <div
                                class="absolute inset-0 z-10 pointer-events-none
                                bg-linear-to-t from-black/70 to-transparent
                                opacity-0 transition-opacity duration-300
                                group-hover:opacity-100 flex items-end p-4"
                            >
                                {project.details}
                            </div>

                            <img
                                src={project.image}
                                alt={project.title}
                                class="w-full h-full object-cover
                                transition-transform duration-300
                                group-hover:scale-110"
                            />
                        </div>
                        <div class="p-6 space-y-4">
                            <h3 class="text-xl md:text-2xl font-bold text-white">
                                {project.title}
                            </h3>
                            <p class="text-gray-300">{project.description}</p>
                            <div class="flex space-x-2">
                                {project.stack.map((tech) => (
                                    <span class="px-2 py-1 bg-white/10 rounded-lg text-sm text-gray-300">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                            <div class="flex space-x-4 mt-10">
                                <a
                                    href={project.repo}
                                    class="flex items-center justify-center gap-2 rounded-full bg-amber-900/20 border border-amber-800 text-amber-400 hover:bg-amber-900/40 hover:border-amber-600 px-6 py-3 font-semibold transition-all duration-300"
                                >
                                    <icon.Github className="h-5 w-5" />
                                    Código
                                </a>

                                <a
                                    href={project.demo}
                                    class="flex items-center justify-center gap-2 rounded-full bg-cyan-900/20 border border-cyan-800 text-cyan-400 hover:bg-cyan-900/40 hover:border-cyan-600 px-6 py-3 font-semibold transition-all duration-300"
                                >
                                    <icon.ExternalLink className="h-5 w-5" />
                                    Live Demo
                                </a>
                            </div>
                        </div>
                    </div>
                );
            })
        }
    </div>
</section>
