---
import * as icon from "lucide-react";

const projects = [
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
    {
        title: "poyecto-1",
        description: "Descripción del proyecto 1",
        demo: "#",
        repo: "#",
        stack: ["1221", "daddq", "dwqdqw"],
        image: "/logos/typescript.svg",
    },
];
---

<section
    id="stack"
    class="min-h-screen flex container mx-auto px-6 md:px-20 py-20 space-y-10"
>
    <div class="flex w-full items-center justify-between gap-6">
        {
            projects.map((project) => {
                return (
                    <div class="border border-white/50 flex-1 rounded-2xl overflow-hidden transition-all duration-300">
                        <div class="relative h-100 overflow-hidden group">
                            <div
                                class="absolute inset-0 z-10 pointer-events-none
                                bg-linear-to-t from-black/70 to-transparent
                                opacity-0 transition-opacity duration-300
                                group-hover:opacity-100 flex items-end p-4"
                            ></div>

                            <img
                                src={project.image}
                                alt={project.title}
                                class="w-full h-full object-cover
                                transition-transform duration-300
                                group-hover:scale-110"
                            />
                        </div>
                        <div class="p-6 space-y-4">
                            <h3 class="text-xl md:text-2xl font-bold text-white">
                                {project.title}
                            </h3>
                            <p class="text-gray-300">{project.description}</p>
                            <div class="flex space-x-2">
                                {project.stack.map((tech) => (
                                    <span class="px-2 py-1 bg-white/10 rounded-full text-sm text-gray-300">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                            <div class="flex space-x-4 mt-10">
                                <a
                                    href={project.repo}
                                    class="flex items-center gap-1 bg-white/10 rounded-full px-3 py-1 text-gray-300 hover:bg-white/20 transition"
                                >
                                    <icon.Github className="h-5 w-5" />
                                    Código
                                </a>
                                <a
                                    href={project.demo}
                                    class="flex items-center gap-1 bg-white/10 rounded-full px-3 py-1 text-gray-300 hover:bg-white/20 transition"
                                >
                                    <icon.ExternalLink className="h-5 w-5" />
                                    Live Demo
                                </a>
                            </div>
                        </div>
                    </div>
                );
            })
        }
    </div>
</section>
