                    hover:shadow-2xl shadow-purple-500/30"
            >
              <img src={tech.icon} alt={tech.name} class="h-10 w-auto" />
              <span class="text-xs font-medium text-center">{tech.name}</span>
            </div>
          ))
        }
      </div>
    </div> -->
  </div>
</section>
