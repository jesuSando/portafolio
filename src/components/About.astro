---
import * as icon from "lucide-react";

const items = [
  {
    title: "Inicio de Formación en Programación",
    date: "2024",
    description:
      "Comienzo de la carrera de Analista Programador Computacional, adquiriendo bases en desarrollo de software y aplicaciones web.",
    icon: icon.BookOpen,
  },
  {
    title: "Ingreso al Mundo Laboral",
    date: "Abril 2025",
    description:
      "Inicio de práctica profesional en empresa tecnológica, participando en proyectos reales de desarrollo web.",
    icon: icon.Briefcase,
  },
  {
    title: "Titulación Profesional",
    date: "Agosto 2025",
    description:
      "Obtención del título de Analista Programador Computacional y consolidación como miembro activo del equipo de desarrollo.",
    icon: icon.GraduationCap,
  },
  {
    title: "Desarrollador Web Full Stack",
    date: "2025 – Presente",
    description:
      "Desarrollo de aplicaciones web y APIs REST utilizando React, Next.js, Node.js y bases de datos relacionales.",
    icon: icon.Code2,
  },
];

const getTimelineColor = (index: number, total: number) => {
  const ratio = index / (total - 1);
  if (ratio <= 0.25) return "emerald";
  if (ratio <= 0.5) return "cyan";
  if (ratio <= 0.75) return "blue";
  return "emerald";
};

const timelineColors = ["emerald", "cyan", "blue", "cyan", "emerald"];

const colorMap = {
  emerald: {
    dot: "bg-emerald-500",
    text: "text-emerald-400",
    border: "hover:border-emerald-500/30",
    glow: "shadow-emerald-500/30",
    gradient: "from-emerald-500 to-emerald-400",
    lineFrom: "from-emerald-500/70",
    lineTo: "to-emerald-500/70",
  },
  cyan: {
    dot: "bg-cyan-500",
    text: "text-cyan-400",
    border: "hover:border-cyan-500/30",
    glow: "shadow-cyan-500/30",
    gradient: "from-cyan-500 to-cyan-400",
    lineFrom: "from-cyan-500/70",
    lineTo: "to-cyan-500/70",
  },
  blue: {
    dot: "bg-blue-500",
    text: "text-blue-400",
    border: "hover:border-blue-500/30",
    glow: "shadow-blue-500/30",
    gradient: "from-blue-500 to-blue-400",
    lineFrom: "from-blue-500/70",
    lineTo: "to-blue-500/70",
  },
};
---

<section
  id="about"
  class="min-h-screen container mx-auto flex flex-col items-center justify-center px-20"
>
  <div class="h-full flex items-center justify-center gap-10">
    <div
      class="flex-1 flex flex-col items-center justify-center h-full text-xl space-y-10"
    >
      <h2 class="text-2xl md:text-5xl font-bold gradient-text-green py-3 w-full">
        Experiencia y Formación Académica
      </h2>
      <p>
        Soy Jesús Sandoval, desarrollador web Full Stack y Analista Programador
        Computacional, con experiencia en proyectos reales desde mis primeros
        meses de formación y participación temprana en entornos productivos.
      </p>
      <p>
        Me enfoco en construir aplicaciones web claras y bien estructuradas,
        priorizando mantenibilidad, buenas prácticas y experiencia de usuario.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <icon.Brain className="text-emerald-400 mb-2" />
          <h4 class="font-semibold text-white">Pensamiento lógico</h4>
          <p class="text-sm text-gray-400">
            Análisis de problemas y búsqueda de soluciones claras y eficientes.
          </p>
        </div>

        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <icon.Wrench className="text-cyan-400 mb-2" />
          <h4 class="font-semibold text-white">Aprendizaje constante</h4>
          <p class="text-sm text-gray-400">
            Mejora continua a través de práctica, estudio y proyectos reales.
          </p>
        </div>
      </div>
    </div>

    <div class="flex-1 flex flex-col items-center justify-center h-full">

      <div class="w-full max-w-4xl mx-auto">
        <div class="relative">
          <div
            class="absolute
          left-1/2
          top-0
          h-full
          w-1
          -translate-x-1/2
          bg-gradient-to-b
          from-emerald-500/90 from-0%
          via-cyan-500/70 via-25%
          via-blue-500/50 via-50%
          via-cyan-500/70 via-75%
          to-emerald-500/90 to-100%"
          >
          </div>

          <div
            class="absolute left-1/2 top-0 w-5 h-5 bg-emerald-500 rounded-full -translate-x-1/2"
          >
          </div>
          <div
            class="absolute left-1/2 bottom-0 w-5 h-5 bg-emerald-500 rounded-full -translate-x-1/2"
          >
          </div>

          <div class="space-y-2">
            {
              items.map((item, index) => {
                const isLeft = index % 2 === 0;
                const isLast = index === items.length - 1;
                const color = getTimelineColor(index, items.length);
                const theme = colorMap[color];

                return (
                  <div
                    class={`relative flex w-full items-center ${isLeft ? "justify-start" : "justify-end"}`}
                  >
                    <div class={`w-[45%] ${isLeft ? "pr-12" : "pl-12"} group`}>
                      <div
                        class={`
                    relative p-6 rounded-2xl transition-all duration-300 
                    bg-white/5 backdrop-blur-sm border border-white/10
                    hover:bg-white/10 ${theme.border}
                    hover:shadow-2xl ${theme.glow}
                    ${isLeft ? "hover:-translate-x-2" : "hover:translate-x-2"}
                  `}
                      >
                        <div>
                          <div class="flex items-center gap-2 mb-2">
                            {isLast && (
                              <div class="w-2 h-2 rounded-full bg-emerald-500 animate-ping" />
                            )}
                            <p class={`text-sm font-medium ${theme.text}`}>
                              {item.date}
                            </p>
                          </div>

                          <h3 class="text-xl font-bold text-white mb-2">
                            {item.title}
                          </h3>

                          <p class="text-gray-300">{item.description}</p>
                        </div>
                      </div>
                    </div>

                    <div class="absolute left-1/2 z-10 -translate-x-1/2">
                      <div class="relative">
                        <div
                          class={`p-2 rounded-full bg-gradient-to-r ${theme.gradient} shadow-lg ${theme.glow}`}
                        >
                          <item.icon className="h-5 w-5 text-white" />
                        </div>
                        <div
                          class={`absolute inset-0 rounded-full ${theme.dot} animate-ping opacity-20`}
                        />
                      </div>
                    </div>

                    <div
                      class={`
                  absolute left-1/2 top-[50%] w-20 h-0.5 bg-gradient-to-r
                  ${isLeft ? `${theme.lineFrom} to-transparent -translate-x-full` : `from-transparent ${theme.lineTo}`}
                `}
                    />
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
