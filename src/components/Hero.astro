---
import { Github, Linkedin } from "lucide-react";
---

<section id="hero" class="min-h-screen flex items-center justify-center">
    <div
        class="flex flex-col lg:flex-row items-center justify-center gap-5 px-8"
    >
        <div
            class={`w-full lg:flex-1 mt-20 flex flex-col items-center justify-center transition-all duration-700`}
        >
            <div
                class="relative w-[280px] h-[280px] sm:w-[350px] sm:h-[350px] lg:w-[400px] lg:h-[400px] rounded-full flex items-end justify-center"
            >
                <div
                    class="absolute -inset-3 sm:-inset-4 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full blur-xl opacity-20 animate-pulse z-0"
                >
                </div>

                <img
                    src={"/perfil.png"}
                    alt="Foto de perfil de Jesús Sandoval"
                    class="object-cover rounded-full z-1"
                />

                <div
                    class="absolute inset-0 rounded-full bg-gradient-to-t from-black/90 via-black/10 to-transparent z-2"
                >
                </div>

                <h2
                    class="absolute bottom-[-25px] sm:bottom-[-20px] text-5xl lg:text-7xl text-[var(--text-color)] font-bold text-start drop-shadow-xl z-3"
                >
                    Jesús Sandoval
                </h2>
            </div>
        </div>
        <div
            class={`
                    w-full lg:flex-2 space-y-4 lg:space-y-6 transition-all duration-700 delay-300 

                    }`}
        >
            <div class="mb-2 mt-10 lg:mt-0 lg:mb-4">
                <h1
                    class="text-5xl lg:text-7xl font-light text-[var(--text-color)] mb-2"
                >
                    Hola, soy
                </h1>
            </div>

            <div>
                <h2
                    class="text-3xl lg:text-6xl font-semibold text-[var(--text-color)]"
                >
                    Desarrollador{" "}
                    <span
                        class="gradient-text font-bold"
                    >
                        Full Stack
                    </span>
                </h2>
            </div>

            <div class="space-y-4 lg:space-y-6 ml-0 lg:ml-15 mb-0">
                <div class="flex flex-col lg:flex-row gap-5">
                    <div class="flex gap-5">
                        <a
                            href={"https://github.com/jesuSando/"}
                            class="flex items-center justify-center bg-[var(--primary-900)] border border-[var(--primary-800)] text-[var(--primary-400)] font-bold p-3 rounded-full"
                            title="GitHub"
                        >
                            <Github />
                        </a>
                        <a
                            href={"https://www.linkedin.com/in/jesús-sandoval-martínez-983112292"}
                            class="flex items-center justify-center bg-[var(--secondary-900)] border border-[var(--secondary-800)] text-[var(--secondary-400)] font-bold p-3 rounded-full"
                            title="Linkedin"
                        >
                            <Linkedin />
                        </a>
                    </div>

                    <div
                        class="inline-flex items-center bg-[var(--accent-900)] border border-[var(--accent-800)] px-4 py-2 rounded-xl"
                    >
                        <span
                            class="text-[var(--accent-400)] font-medium text-lg"
                        >
                            Disponible para Proyectos
                        </span>
                    </div>
                </div>

                <p
                    class="text-xl text-[var(--text-color)] leading-relaxed max-w-[600px]"
                >
                    Analista Programador especializado en desarrollo web, creando soluciones eficientes y prácticas. Explora mis proyectos y habilidades aquí.
                </p>

                <div class="flex justify-center lg:justify-start gap-6 py-4">
                    <div class="text-center">
                        <div
                            class="text-2xl font-bold text-[var(--primary-400)]"
                        >
                            8+
                        </div>
                        <div class="text-sm text-[var(--muted-400)]">Meses Exp.</div>
                    </div>
                    <div class="text-center">
                        <div
                            class="text-2xl font-bold text-[var(--secondary-400)]"
                        >
                            15+
                        </div>
                        <div class="text-sm text-[var(--muted-400)]">Proyectos</div>
                    </div>
                    <div class="text-center">
                        <div
                            class="text-2xl font-bold text-[var(--accent-400)]"
                        >
                            19+
                        </div>
                        <div class="text-sm text-[var(--muted-400)]">
                            Tecnologías
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col lg:flex-row items-center gap-4 pt-4">
                <a
                    href="#projects"
                    aria-label="Ir a proyectos"
                    class="flex items-center justify-center px-5 py-3 rounded-full text-lg border-2 border-[var(--secondary-400)] bg-[var(--secondary-400)] hover:bg-[var(--secondary-800)] transition-colors duration-200"
                >
                    Explorar Proyectos
                </a>

                <a
                    href="/docs/CV_Jesus_Sandoval.pdf"
                    download="CV_Jesus_sandoval.pdf"
                    aria-label="Descargar CV"
                    class="flex items-center justify-center px-5 py-3 rounded-full text-lg border-2 border-[var(--highlight-400)] hover:bg-[var(--highlight-400)] transition-all duration-200"
                >
                    Descargar CV
                </a>
            </div>
        </div>
    </div>
</section>
