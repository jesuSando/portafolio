---
import { Github, Linkedin } from "lucide-react";
---

<section
    id="hero"
    class="min-h-screen container mx-auto flex flex-col lg:flex-row items-center justify-center gap-5 px-8"
>
    <div
        class="w-full lg:flex-3 mt-20 flex flex-col items-center lg:items-end justify-center transition-all duration-700"
    >
        <div
            class="relative w-[280px] h-[280px] sm:w-[350px] sm:h-[350px] lg:w-[400px] lg:h-[400px] rounded-full flex items-end justify-center"
        >
            <div
                class="absolute -inset-3 sm:-inset-4 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full blur-xl opacity-20 animate-pulse z-0"
            >
            </div>

            <img
                src={"/perfil.png"}
                alt="Foto de perfil de Jesús Sandoval"
                class="object-cover rounded-full z-1"
            />

            <div
                class="absolute inset-0 rounded-full bg-gradient-to-t from-black/90 via-black/10 to-transparent z-2"
            >
            </div>

            <h2
                class="absolute bottom-[-25px] sm:bottom-[-20px] text-5xl lg:text-7xl text-white font-bold text-start drop-shadow-xl z-3"
            >
                Jesús Sandoval
            </h2>
        </div>
    </div>
    <div
        class={`
                    w-full lg:flex-4 space-y-4 lg:space-y-6 transition-all duration-700 delay-300 

                    }`}
    >
        <div class="mb-2 mt-10 lg:mt-0 lg:mb-4">
            <h1 class="text-5xl lg:text-7xl font-light text-white mb-2">
                Hola, soy
            </h1>
        </div>

        <div>
            <h2 class="text-3xl lg:text-6xl font-semibold text-white">
                Desarrollador{" "}
                <span class="gradient-text-purple font-bold"> Full Stack </span>
            </h2>
        </div>

        <div class="space-y-4 lg:space-y-6 ml-0 lg:ml-15 mb-0">
            <div class="flex flex-col lg:flex-row gap-5">
                <div class="flex gap-5">
                    <a
                        href={"https://github.com/jesuSando/"}
                        class="flex items-center justify-center rounded-full bg-blue-900/20 border border-blue-800 text-blue-400 hover:bg-blue-900/40 hover:border-blue-600 p-3 font-semibold transition-all duration-300"
                        title="GitHub"
                    >
                        <Github />
                    </a>
                    <a
                        href={"https://www.linkedin.com/in/jesús-sandoval-martínez-983112292"}
                        class="flex items-center justify-center rounded-full bg-cyan-900/20 border border-cyan-800 text-cyan-400 hover:bg-cyan-900/40 hover:border-cyan-600 p-3 font-semibold transition-all duration-300"
                        title="Linkedin"
                    >
                        <Linkedin />
                    </a>
                </div>

                <a
                    href="#projects"
                    class="inline-flex items-center px-4 py-2 rounded-xl
                    bg-gradient-to-r from-emerald-900/30 to-emerald-900/20 backdrop-blur-sm border border-emerald-800"
                >
                    <span class="text-green-400 font-medium text-lg">
                        Disponible para Proyectos
                    </span>
                </a>
            </div>

            <p class="text-xl text-white leading-relaxed max-w-[600px]">
                Analista Programador especializado en desarrollo web, creando
                soluciones eficientes y prácticas. Explora mis proyectos y
                habilidades aquí.
            </p>

            <div class="flex justify-center lg:justify-start gap-6 py-4">
                <div class="text-center">
                    <div class="text-2xl font-bold text-blue-400">8+</div>
                    <div class="text-sm text-gray-400">Meses Exp.</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-cyan-400">15+</div>
                    <div class="text-sm text-gray-400">Proyectos</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-green-400">19+</div>
                    <div class="text-sm text-gray-400">Tecnologías</div>
                </div>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row items-center gap-4 pt-4">
            <a
                href="#projects"
                aria-label="Ir a proyectos"
                class="flex items-center justify-center rounded-full bg-amber-900/20 border border-amber-800 text-amber-400 hover:bg-amber-900/40 hover:border-amber-600 px-6 py-3 font-semibold transition-all duration-300"
            >
                Explorar Proyectos
            </a>

            <a
                href="/docs/CV_Jesus_Sandoval.pdf"
                download="CV_Jesus_sandoval.pdf"
                aria-label="Descargar CV"
                class="flex items-center justify-center rounded-full bg-cyan-900/20 border border-cyan-800 text-cyan-400 hover:bg-cyan-900/40 hover:border-cyan-600 px-6 py-3 font-semibold transition-all duration-300"
            >
                Descargar CV
            </a>

            <a
                href="#contact"
                aria-label="Contactarme"
                class="flex items-center justify-center rounded-full bg-blue-900/20 border border-blue-800 text-blue-400 hover:bg-blue-900/40 hover:border-blue-600 px-6 py-3 font-semibold transition-all duration-300"
            >
                Contactar
            </a>
        </div>
    </div>
</section>
