---
import { Github, Linkedin, Mail } from "lucide-react";
import waves from "../assets/footer.svg";
---

<footer id="footer" class="relative w-full overflow-hidden">
  <!-- Imagen del footer -->
  <img
    src={waves.src}
    alt=""
    class="w-full h-[500px] md:h-[600px] object-cover"
  />

  <!-- Overlay suave para legibilidad -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/60 to-transparent"></div>

  <!-- Contenido -->
  <div
    class="absolute inset-0 flex flex-col items-center justify-end pb-10 md:pb-14 px-6 text-center"
  >
    <!-- Nombre / Rol -->
    <h3 class="text-2xl md:text-3xl font-bold text-white">
      Jesús Sandoval
    </h3>
    <p class="text-gray-400 mt-1">
      Desarrollador Full Stack · Analista Programador Computacional
    </p>

    <!-- Links -->
    <div class="flex items-center gap-6 mt-6">
      <a
        href="mailto:jesu.o.sandoval@gmail.com"
        class="p-3 rounded-full bg-white/5 border border-white/10
               hover:bg-emerald-500/10 hover:border-emerald-400
               transition-all"
        aria-label="Email"
      >
        <Mail className="h-5 w-5 text-emerald-400" />
      </a>

      <a
        href="https://github.com/jesuSando/"
        class="p-3 rounded-full bg-white/5 border border-white/10
               hover:bg-blue-500/10 hover:border-blue-400
               transition-all"
        aria-label="GitHub"
      >
        <Github className="h-5 w-5 text-blue-400" />
      </a>

      <a
        href="https://www.linkedin.com/in/jesús-sandoval-martínez-983112292"
        class="p-3 rounded-full bg-white/5 border border-white/10
               hover:bg-cyan-500/10 hover:border-cyan-400
               transition-all"
        aria-label="LinkedIn"
      >
        <Linkedin className="h-5 w-5 text-cyan-400" />
      </a>
    </div>

    <!-- Divider -->
    <div class="w-24 h-px bg-white/20 my-6"></div>

    <!-- Copyright -->
    <p class="text-sm text-gray-500">
      &copy; {new Date().getFullYear()} jesuSando · thx 4 read :p
    </p>
  </div>
</footer>
