---
// Importa tus íconos de lucide-react
import * as icon from "lucide-react";

// Definimos los items
const items = [
  {
    title: "Inicio",
    date: "2024",
    description: "lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    icon: icon.BookOpen
  },
  {
    title: "segundo",
    date: "Abril 2025",
    description: "lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    icon: icon.Briefcase
  },
  {
    title: "tercero",
    date: "Agosto 2025",
    description: "lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    icon: icon.GraduationCap
  },
  {
    title: "cuarto",
    date: "2025 – Presente",
    description: "lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    icon: icon.Code2
  },
];

// Función para obtener colores de la línea
const getTimelineColor = (index, total) => {
  const ratio = index / (total - 1)
  if (ratio <= 0.25) return "emerald"
  if (ratio <= 0.5) return "cyan"
  if (ratio <= 0.75) return "blue"
  return "emerald"
}

const timelineColors = [
  "emerald",
  "cyan",
  "blue",
  "cyan",
  "emerald",
];

const colorMap = {
  emerald: {
    dot: "bg-emerald-500",
    text: "text-emerald-400",
    border: "hover:border-emerald-500/30",
    glow: "shadow-emerald-500/30",
    gradient: "from-emerald-500 to-emerald-400",
    lineFrom: "from-emerald-500/70",
    lineTo: "to-emerald-500/70",
  },
  cyan: {
    dot: "bg-cyan-500",
    text: "text-cyan-400",
    border: "hover:border-cyan-500/30",
    glow: "shadow-cyan-500/30",
    gradient: "from-cyan-500 to-cyan-400",
    lineFrom: "from-cyan-500/70",
    lineTo: "to-cyan-500/70",
  },
  blue: {
    dot: "bg-blue-500",
    text: "text-blue-400",
    border: "hover:border-blue-500/30",
    glow: "shadow-blue-500/30",
    gradient: "from-blue-500 to-blue-400",
    lineFrom: "from-blue-500/70",
    lineTo: "to-blue-500/70",
  },
};
---

<div class="min-h-screen flex items-center justify-center p-4">
  <div class="flex-1 flex items-center justify-center h-full">
    Lorem ipsum dolor sit amet consectetur adipisicing elit. Dolore dicta harum, ut consequuntur quis aliquam expedita ducimus. Magni, ut eum debitis tempora, nihil eligendi saepe ipsam rem, reiciendis doloremque explicabo.
  </div>

  <div class="flex-1 flex items-center justify-center h-full">
    <div class="w-full max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">
          Historial del Proyecto
        </h2>
      </div>

      <div class="relative">
        <div class="
          absolute
          left-1/2
          top-0
          h-full
          w-1
          -translate-x-1/2
          bg-gradient-to-b
          from-emerald-500/90 from-0%
          via-cyan-500/70 via-25%
          via-blue-500/50 via-50%
          via-cyan-500/70 via-75%
          to-emerald-500/90 to-100%
        " />

        <div class="absolute left-1/2 top-0 w-5 h-5 bg-emerald-500 rounded-full -translate-x-1/2" />
        <div class="absolute left-1/2 bottom-0 w-5 h-5 bg-emerald-500 rounded-full -translate-x-1/2" />

        <div class="space-y-12">
          {items.map((item, index) => {
            const isLeft = index % 2 === 0
            const isLast = index === items.length - 1
            const color = getTimelineColor(index, items.length)
            const theme = colorMap[color]

            return (
              <div
                class={`relative flex w-full items-center ${isLeft ? "justify-start" : "justify-end"}`}
              >
                <div class={`w-[45%] ${isLeft ? "pr-12" : "pl-12"} group`}>
                  <div class={`
                    relative p-6 rounded-2xl transition-all duration-300 
                    bg-white/5 backdrop-blur-sm border border-white/10
                    hover:bg-white/10 ${theme.border}
                    hover:shadow-2xl ${theme.glow}
                    ${isLeft ? "hover:-translate-x-2" : "hover:translate-x-2"}
                  `}>
                    <div>
                      <div class="flex items-center gap-2 mb-2">
                        {isLast && <div class="w-2 h-2 rounded-full bg-emerald-500 animate-ping" />}
                        <p class={`text-sm font-medium ${theme.text}`}>
                          {item.date}
                        </p>
                      </div>

                      <h3 class="text-xl font-bold text-white mb-2">
                        {item.title}
                      </h3>

                      <p class="text-gray-300">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </div>

                <div class="absolute left-1/2 z-10 -translate-x-1/2">
                  <div class="relative">
                    <div class={`p-2 rounded-full bg-gradient-to-r ${theme.gradient} shadow-lg ${theme.glow}`}>
                      <item.icon class="h-5 w-5 text-white" />
                    </div>
                    <div class={`absolute inset-0 rounded-full ${theme.dot} animate-ping opacity-20`} />
                  </div>
                </div>

                <div class={`
                  absolute left-1/2 top-[50%] w-20 h-0.5 bg-gradient-to-r
                  ${isLeft ? `${theme.lineFrom} to-transparent -translate-x-full` : `from-transparent ${theme.lineTo}`}
                `} />
              </div>
            )
          })}
        </div>
      </div>
    </div>
  </div>
</div>
